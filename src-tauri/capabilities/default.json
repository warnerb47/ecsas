{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "fs:default",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-create",
    "fs:allow-write",
    "fs:allow-write-file",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        }
      ]
    },
    "shell:default",
    "http:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/hello-script/hello-script",
          "sidecar": true,
          "args": true
        },
        {
          "name": "binaries/llama-server/llama-server",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "dialog:default",
     {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        }
      ]
    }
  ]
}
