{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "fs:default",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-create",
    "fs:allow-write",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPLOCALDATA/**" }]
    }
  ]
}
