{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ecsas",
  "version": "0.1.0",
  "identifier": "ecsas",
  "build": {
    "frontendDist": "../dist/apps/ecsas/browser",
    "devUrl": "http://localhost:4201",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ecsas",
        "width": 1200,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
    "plugins": {
    "asset": {
      "scope": ["$APPLOCALDATA/**/*"]
    }
  }
}
